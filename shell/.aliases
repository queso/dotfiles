alias gca="git commit --amend --author='Josh Owens <joshua.owens@gmail.com>'"

# SSH into magi and attach/create a named tmux session
magi() {
  local session="${1:-default}"
  ssh -t magi.theowens.casa "tmux new-session -As $session"
}

# Encrypt/decrypt CBT therapy files with age
cbt_lock() {
  local dir="$HOME/Code/Brain/Health/mental"
  local key="$HOME/.age/brain-key.txt"
  for f in "$dir"/*.md; do
    [ -f "$f" ] || continue
    age -R "$key" -o "${f}.age" "$f" && rm "$f"
  done
  echo "CBT files locked."
}

cbt_unlock() {
  local dir="$HOME/Code/Brain/Health/mental"
  local key="$HOME/.age/brain-key.txt"
  for f in "$dir"/*.md.age; do
    [ -f "$f" ] || continue
    age -d -i "$key" -o "${f%.age}" "$f" && rm "$f"
  done
  echo "CBT files unlocked."
}
